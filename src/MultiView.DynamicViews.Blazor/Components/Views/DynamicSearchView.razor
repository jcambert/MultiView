@using MudBlazor
@using MultiView.DynamicViews.Core.Abstractions
@using MultiView.DynamicViews.Domain.Model
@using MultiView.DynamicViews.Blazor.Components.Fields
@using System.Globalization
@using System.Text.Json

<MudPaper Class="p-3">
    @if (string.IsNullOrWhiteSpace(Definition.Title) == false)
    {
        <MudText Typo="Typo.h5" Class="mb-3">@Definition.Title</MudText>
    }

    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
        Définissez un filtre texte et/ou des critères ciblés.
    </MudText>

    <MudTextField
        T="string"
        Value="SearchText"
        ValueChanged="OnSearchTextChanged"
        Label="Recherche"
        Placeholder="Rechercher..."
        Variant="Variant.Outlined"
        Margin="Margin.Dense"
        FullWidth="true"
        Clearable="true"
        Class="mb-3" />

    <MudGrid Class="mb-4" Spacing="2">
        @foreach (ViewFieldDefinition fieldDefinition in SearchFields)
        {
            <MudItem xs="12" sm="@(GetFilterWidth(fieldDefinition))">
                <DynamicFieldRenderer
                    @key="fieldDefinition.Name"
                    Record="_filterRecord"
                    FieldDefinition="fieldDefinition"
                    EnabledDefault="true"
                    VisibleDefault="true"
                    DisplayOnlyMode="false"
                    ValueChanged="OnFilterValueChanged" />
            </MudItem>
        }
    </MudGrid>

    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-3" Wrap="Wrap.Wrap">
        <MudText Typo="Typo.caption">@GetSummary()</MudText>

        @if (EnablePaging)
        {
            <MudSelect T="int" Label="Éléments / page" Value="_pageSize" ValueChanged="OnPageSizeChanged">
                @foreach (int size in _availablePageSizes)
                {
                    <MudSelectItem Value="@size">@size</MudSelectItem>
                }
            </MudSelect>

            <MudSpacer />
            <MudText Typo="Typo.caption">Page @(_currentPageIndex + 1) / @TotalPages</MudText>
            <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="PreviousPage" Disabled="@(!CanGoPrevious)">
                Précédent
            </MudButton>
            <MudButton Variant="Variant.Filled" Size="Size.Small" OnClick="NextPage" Disabled="@(!CanGoNext)">
                Suivant
            </MudButton>
        }
    </MudStack>

    @if (VisibleRecords.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Elevation="0">
            Aucun résultat.
        </MudAlert>
    }
    else
    {
        <MudTable T="object" Items="VisibleRecords" Dense="true" Hover="true" Elevation="0">
            <HeaderContent>
                @foreach (string column in Columns)
                {
                    <MudTh @onclick="() => ToggleSort(column)" Style="cursor: pointer;">
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            <span>@GetColumnTitle(column)</span>
                            @if (_sortField is not null && string.Equals(_sortField, column, StringComparison.OrdinalIgnoreCase))
                            {
                                <MudText Typo="Typo.caption">@(_sortAscending ? "▲" : "▼")</MudText>
                            }
                        </MudStack>
                    </MudTh>
                }
            </HeaderContent>
            <RowTemplate Context="record">
                @foreach (string column in Columns)
                {
                    <MudTd DataLabel="@(GetColumnTitle(column))">
                        @FormatValue(record, column)
                    </MudTd>
                }
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@code {
    [Inject]
    private IRecordPropertyAccessor PropertyAccessor { get; set; } = null!;

    [Parameter]
    public SearchViewDefinition Definition { get; set; } = null!;

    [Parameter]
    public IReadOnlyList<object> Records { get; set; } = Array.Empty<object>();

    private readonly Dictionary<string, object?> _filters = new(StringComparer.OrdinalIgnoreCase);
    private string SearchText { get; set; } = string.Empty;
    private object _filterRecord => _filters;
    private readonly int[] _availablePageSizes = [5, 10, 20, 50, 100];
    private bool EnablePaging => Definition.EnablePaging;
    private string? _sortField;
    private bool _sortAscending = true;
    private int _currentPageIndex;
    private int _pageSize = 10;

    private IReadOnlyList<object> SortedRecords =>
        string.IsNullOrWhiteSpace(_sortField)
            ? FilteredRecords
            : [.. FilteredRecords.OrderBy(record => record, new SearchFieldComparer(record => PropertyAccessor.GetValue(record, _sortField), _sortAscending))];

    private IReadOnlyList<object> VisibleRecords
    {
        get
        {
            if (!EnablePaging)
            {
                return SortedRecords;
            }

            EnsurePagingBounds();
            int skip = _currentPageIndex * _pageSize;
            return [.. SortedRecords.Skip(skip).Take(_pageSize)];
        }
    }

    private int TotalRecords => SortedRecords.Count;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(TotalRecords / (double)_pageSize));
    private bool CanGoPrevious => _currentPageIndex > 0;
    private bool CanGoNext => _currentPageIndex + 1 < TotalPages;

    private IReadOnlyList<ViewFieldDefinition> SearchFields =>
        Definition.SearchFields.Count > 0
            ? Definition.SearchFields
                .Select(fieldName => Definition.Fields.FirstOrDefault(fieldDefinition =>
                    string.Equals(fieldDefinition.Name, fieldName, StringComparison.OrdinalIgnoreCase)))
                .Where(fieldDefinition => fieldDefinition is not null)
                .Select(CreateSearchFieldDefinition)
                .OfType<ViewFieldDefinition>()
                .ToList()!
            : Definition.Fields
                .Select(CreateSearchFieldDefinition)
                .OfType<ViewFieldDefinition>()
                .ToList();

    private IReadOnlyList<string> Columns => Definition.SearchFields.Count > 0
        ? Definition.SearchFields
        : Definition.Fields.Select(viewFieldDefinition => viewFieldDefinition.Name).ToList();

    private IReadOnlyList<object> FilteredRecords
    {
        get
        {
            IEnumerable<object> source = Records;

            if (HasFilterCriteria())
            {
                source = source.Where(MatchesFilters);
            }

            if (!string.IsNullOrWhiteSpace(SearchText))
            {
                source = source.Where(MatchesSearch);
            }

            return [.. source];
        }
    }

    protected override void OnParametersSet()
    {
        EnsureFilterKeys();
        EnsureInitialSorting();
        SyncPagingState();
    }

    private bool MatchesSearch(object record)
    {
        string query = SearchText.Trim();
        if (query.Length == 0)
        {
            return true;
        }

        return Columns
            .Select(column => FormatValue(record, column))
            .Any(value => value.Contains(query, StringComparison.OrdinalIgnoreCase));
    }

    private bool MatchesFilters(object record)
    {
        foreach (ViewFieldDefinition field in SearchFields)
        {
            if (!_filters.TryGetValue(field.Name, out object? filterValue) || !HasValueForFilter(filterValue))
            {
                continue;
            }

            object? recordValue = PropertyAccessor.GetValue(record, field.Name);
            if (!MatchesFilterValue(recordValue, filterValue, field))
            {
                return false;
            }
        }

        return true;
    }

    private static bool HasValueForFilter(object? value)
    {
        return value switch
        {
            null => false,
            string text => !string.IsNullOrWhiteSpace(text),
            _ => true
        };
    }

    private bool MatchesFilterValue(object? recordValue, object? filterValue, ViewFieldDefinition field)
    {
        if (recordValue is null || filterValue is null)
        {
            return false;
        }

        string resolvedSearchWidget = string.IsNullOrWhiteSpace(field.Widget)
            ? field.Kind.ToString()
            : field.Widget;
        bool isDropdown = string.Equals(
            resolvedSearchWidget,
            "select",
            StringComparison.OrdinalIgnoreCase);

        if (isDropdown)
        {
            return string.Equals(recordValue.ToString(), filterValue.ToString(), StringComparison.OrdinalIgnoreCase);
        }

        if (field.Kind == ViewFieldKind.Boolean && filterValue is bool expectedBoolean)
        {
            return TryConvertToBoolean(recordValue, out bool currentBoolean) && expectedBoolean == currentBoolean;
        }

        string filterText = filterValue.ToString() ?? string.Empty;
        string recordText = recordValue.ToString() ?? string.Empty;

        return recordText.Contains(filterText, StringComparison.OrdinalIgnoreCase);
    }

    private bool HasFilterCriteria()
    {
        return _filters.Values.Any(HasValueForFilter);
    }

    private int GetFilterWidth(ViewFieldDefinition fieldDefinition)
    {
        return fieldDefinition.Kind == ViewFieldKind.Boolean ? 2 : 4;
    }

    private static bool TryConvertToBoolean(object value, out bool booleanValue)
    {
        if (value is bool valueAsBoolean)
        {
            booleanValue = valueAsBoolean;
            return true;
        }

        if (value is string valueAsString && bool.TryParse(valueAsString, out booleanValue))
        {
            return true;
        }

        if (value is int intValue)
        {
            booleanValue = intValue != 0;
            return true;
        }

        if (value is decimal decimalValue)
        {
            booleanValue = decimalValue != 0m;
            return true;
        }

        booleanValue = false;
        return false;
    }

    private void EnsureFilterKeys()
    {
        foreach (ViewFieldDefinition fieldDefinition in SearchFields)
        {
            if (!_filters.ContainsKey(fieldDefinition.Name))
            {
                _filters[fieldDefinition.Name] = null;
            }
        }

        foreach (string key in _filters.Keys
                     .Where(key => SearchFields.All(fieldDefinition =>
                         !string.Equals(fieldDefinition.Name, key, StringComparison.OrdinalIgnoreCase)))
                     .ToList())
        {
            _filters.Remove(key);
        }
    }

    private string FormatValue(object record, string field)
    {
        if (record is null || string.IsNullOrWhiteSpace(field))
        {
            return string.Empty;
        }

        object? value = PropertyAccessor.GetValue(record, field);
        return value switch
        {
            null => string.Empty,
            DateTime dateTime => dateTime.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture),
            decimal amount => amount.ToString("N2", CultureInfo.InvariantCulture),
            double amount => amount.ToString("N2", CultureInfo.InvariantCulture),
            float amount => amount.ToString("N2", CultureInfo.InvariantCulture),
            bool booleanValue => booleanValue ? "Oui" : "Non",
            _ => value.ToString() ?? string.Empty
        };
    }

    private static string GetColumnTitle(string field)
    {
        return field;
    }

    private static ViewFieldDefinition? CreateSearchFieldDefinition(ViewFieldDefinition? source)
    {
        if (source is null)
        {
            return null;
        }

        string? resolvedSearchWidget = string.IsNullOrWhiteSpace(source.SearchWidget)
            ? source.Widget
            : source.SearchWidget;

        JsonElement? resolvedSearchOptions = source.SearchWidgetOptions ?? source.WidgetOptions;

        if (string.IsNullOrWhiteSpace(source.SearchLabel)
            && string.IsNullOrWhiteSpace(resolvedSearchWidget)
            && resolvedSearchOptions is null)
        {
            return source;
        }

        return new ViewFieldDefinition
        {
            Name = source.Name,
            Label = string.IsNullOrWhiteSpace(source.SearchLabel) ? source.Label : source.SearchLabel,
            Kind = source.Kind,
            Widget = resolvedSearchWidget,
            Format = source.Format,
            CssClass = source.CssClass,
            DefaultValue = source.DefaultValue,
            WidgetOptions = resolvedSearchOptions,
            Rules = source.Rules
        };
    }

    private void OnFilterValueChanged(object? _)
    {
        _currentPageIndex = 0;
        StateHasChanged();
    }

    private void OnSearchTextChanged(string value)
    {
        SearchText = value;
        _currentPageIndex = 0;
    }

    private void ToggleSort(string field)
    {
        if (_sortField is not null && string.Equals(_sortField, field, StringComparison.OrdinalIgnoreCase))
        {
            _sortAscending = !_sortAscending;
        }
        else
        {
            _sortField = field;
            _sortAscending = true;
        }

        _currentPageIndex = 0;
    }

    private void PreviousPage()
    {
        if (CanGoPrevious)
        {
            _currentPageIndex--;
        }
    }

    private void NextPage()
    {
        if (CanGoNext)
        {
            _currentPageIndex++;
        }
    }

    private void OnPageSizeChanged(int newPageSize)
    {
        int safePageSize = newPageSize <= 0 ? 10 : newPageSize;
        if (_pageSize != safePageSize)
        {
            _pageSize = safePageSize;
            _currentPageIndex = 0;
        }
    }

    private string GetSummary()
    {
        return EnablePaging
            ? $"{TotalRecords} résultat(s) - page {_currentPageIndex + 1}/{TotalPages}"
            : $"{TotalRecords} résultat(s)";
    }

    private void EnsureInitialSorting()
    {
        _sortField ??= Columns.FirstOrDefault();
        if (_sortField is not null && !Columns.Any(column => string.Equals(column, _sortField, StringComparison.OrdinalIgnoreCase)))
        {
            _sortField = Columns.FirstOrDefault();
        }

        if (_sortField is null)
        {
            _sortAscending = true;
        }
    }

    private void SyncPagingState()
    {
        _pageSize = Definition.DefaultPageSize ?? _pageSize;
        if (_pageSize <= 0)
        {
            _pageSize = 10;
        }

        EnsurePagingBounds();
    }

    private void EnsurePagingBounds()
    {
        if (_pageSize <= 0)
        {
            _pageSize = 10;
        }

        if (_currentPageIndex >= TotalPages)
        {
            _currentPageIndex = Math.Max(0, TotalPages - 1);
        }

        if (_currentPageIndex < 0)
        {
            _currentPageIndex = 0;
        }
    }

    private sealed class SearchFieldComparer(
        Func<object, object?> selector,
        bool ascending) : IComparer<object>
    {
        public int Compare(object? x, object? y)
        {
            int comparison = CompareValues(selector(x!), selector(y!));
            return ascending ? comparison : -comparison;
        }

        private static int CompareValues(object? left, object? right)
        {
            if (left is null && right is null)
            {
                return 0;
            }

            if (left is null)
            {
                return -1;
            }

            if (right is null)
            {
                return 1;
            }

            if (left is bool leftBoolean && right is bool rightBoolean)
            {
                return leftBoolean.CompareTo(rightBoolean);
            }

            if (TryGetDecimal(left, out decimal leftDecimal) && TryGetDecimal(right, out decimal rightDecimal))
            {
                return leftDecimal.CompareTo(rightDecimal);
            }

            if (left is DateTime leftDate && right is DateTime rightDate)
            {
                return leftDate.CompareTo(rightDate);
            }

            return string.Compare(
                left.ToString(),
                right.ToString(),
                StringComparison.OrdinalIgnoreCase);
        }

        private static bool TryGetDecimal(object value, out decimal result)
        {
            switch (value)
            {
                case decimal decimalValue:
                    result = decimalValue;
                    return true;
                case double doubleValue:
                    result = (decimal)doubleValue;
                    return true;
                case float floatValue:
                    result = (decimal)floatValue;
                    return true;
                case int intValue:
                    result = intValue;
                    return true;
                case long longValue:
                    result = longValue;
                    return true;
                case string text when decimal.TryParse(text, NumberStyles.Any, CultureInfo.InvariantCulture, out result):
                    return true;
                default:
                    result = 0m;
                    return false;
            }
        }
    }
}
